{
  // START Editor settings
  "editor.lineNumbers": "relative",
  "editor.linkedEditing": true,
  "editor.formatOnSave": true,
  "editor.wordWrap": "off",
  // FONTS
  "editor.fontFamily": "'GeistMono Nerd Font', 'JetBrains Mono NL', 'JetBrains Mono', 'Fira Code', Menlo, Monaco, 'Courier New', monospace",
  "terminal.integrated.fontFamily": "'GeistMono Nerd Font', 'Hack Nerd Font Mono', monospace",
  "editor.minimap.enabled": false,
  "explorer.compactFolders": false,
  "explorer.fileNesting.enabled": true,
  // "editor.foldingImportsByDefault": true,
  "json.schemaDownload.enable": true,
  "editor.inlayHints.enabled": "off",
  "editor.rulers": [
    80
  ],
  "workbench.sideBar.location": "right",
  "workbench.colorTheme": "GitHub Dark Default",
  "workbench.productIconTheme": "icons-carbon",
  "workbench.tree.enableStickyScroll": true,
  "git.openRepositoryInParentFolders": "never",
  "editor.suggestSelection": "first",
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "tailwindCSS.colorDecorators": false,
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.experimental.classRegex": [
    [
      "cva\\(([^)]*)\\)",
      "[\"'`]([^\"'`]*).*?[\"'`]"
    ]
  ],
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.autoClosingTags": true,
  "typescript.preferences.renameMatchingJsxTags": true,
  // Update import path when moving files
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
    "+layout.svelte": "+layout.js, +layout.ts, +layout.server.js, +layout.server.ts",
    "+page.svelte": "+page.js, +page.ts, +page.server.js, +page.server.ts",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },
  "typescript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "telemetry.telemetryLevel": "off",
  "git.confirmSync": false,
  "errorLens.excludeBySource": [
    "eslint(no-empty-pattern)"
  ],
  "explorer.confirmDragAndDrop": false,
  "errorLens.fontStyleItalic": true,
  "workbench.activityBar.location": "top",
  "editor.fontSize": 14,
  "workbench.editor.enablePreview": false,
  "chat.agent.maxRequests": 40,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "files.autoSaveDelay": 200,
  "git.autofetch": true,
  "chat.tools.terminal.autoApprove": {
    "sed": true,
    "bun": true,
    "just": true,
    "mkdir": true,
    "mv": true
  },
  "terminal.integrated.stickyScroll.enabled": false,
  "chat.mcp.gallery.enabled": true,
  "python.analysis.typeCheckingMode": "standard",
  "github.copilot.nextEditSuggestions.enabled": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "workbench.iconTheme": "catppuccin-frappe",
  "zig.zls.enabled": "on",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },
  "chat.tools.urls.autoApprove": {
    "https://code.visualstudio.com": true,
    "https://github.com/microsoft/vscode/wiki/*": true,
    "https://tanstack.com": {
      "approveRequest": true,
      "approveResponse": false
    }
  },
  "[html]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}